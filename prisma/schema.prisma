generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Position {
  id               String            @id @default(uuid())
  companyId        String            @default("1") @map("company_id")
  name             String            @db.VarChar(100)
  description      String?           @db.Text
  createdAt        DateTime          @default(now()) @map("created_at")
  employeeProfiles EmployeeProfile[]
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@map("positions")
}

model Department {
  id               String            @id @default(uuid())
  companyId        String            @default("1") @map("company_id")
  name             String            @db.VarChar(100)
  description      String?           @db.Text
  createdAt        DateTime          @default(now()) @map("created_at")
  employeeProfiles EmployeeProfile[]
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@map("departments")
}

model Role {
  id               String            @id @default(uuid())
  companyId        String            @default("1") @map("company_id")
  name             String            @db.VarChar(50)
  description      String?           @db.Text
  createdAt        DateTime          @default(now()) @map("created_at")
  employeeProfiles EmployeeProfile[]
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  RoleNavigation   RoleNavigation[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("roles")
}

model EmployeeStatusModel {
  id               String                  @id @default(uuid())
  name             String                  @unique @db.VarChar(50)
  description      String?                 @db.Text
  color            String                  @default("gray") @db.VarChar(20)
  sortOrder        Int                     @default(0) @map("sort_order")
  createdAt        DateTime                @default(now()) @map("created_at")
  archivedAt       DateTime?               @map("archived_at")
  archivedBy       String?                 @map("archived_by")
  archived         Boolean                 @default(false)
  employeeProfiles EmployeeProfile[]
  statusHistory    EmployeeStatusHistory[]

  @@map("employee_statuses")
}

model Industry {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  brands      Brand[]

  @@map("industries")
}

enum CompanyStatus {
  active
  inactive
  suspended
  trial
}

model Company {
  id        String        @id @default(uuid())
  name      String        @unique @db.VarChar(150)
  status    CompanyStatus @default(active)
  timezone  String        @default("Asia/Manila") @db.VarChar(50)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  profiles                  CompanyProfile[]
  users                     User[]
  brands                    Brand[]
  teams                     Team[]
  positions                 Position[]
  departments               Department[]
  roles                     Role[]
  calendarEvents            CalendarEvent[]
  leaveTypes                LeaveType[]
  leaveStatuses             LeaveStatus[]
  leaveRequests             LeaveRequest[]
  infractionTypes           InfractionType[]
  infractionOffenses        InfractionOffense[]
  infractions               Infraction[]
  workSchedules             WorkSchedule[]
  FeatureNavigationTemplate FeatureNavigationTemplate[]
  RoleNavigation            RoleNavigation[]

  @@map("companies")
}

model CompanyProfile {
  id        String   @id @default(uuid())
  companyId String   @unique @map("company_id")
  legalName String?  @map("legal_name") @db.VarChar(200)
  taxId     String?  @map("tax_id") @db.VarChar(50)
  email     String?  @db.VarChar(200)
  phone     String?  @db.VarChar(50)
  address   String?  @db.Text
  city      String?  @db.VarChar(100)
  country   String?  @db.VarChar(100)
  settings  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_profiles")
}

model User {
  id                      String                  @id @default(uuid())
  companyId               String                  @default("1") @map("company_id")
  username                String                  @unique @db.VarChar(50)
  passwordHash            String                  @map("password_hash") @db.VarChar(255)
  salt                    String                  @db.VarChar(255)
  createdAt               DateTime                @default(now()) @map("created_at")
  employeeProfile         EmployeeProfile?
  teamMembers             TeamMember[]
  company                 Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  calendarEvents          CalendarEvent[]
  leaveCredits            LeaveCredit[]
  leaveRequests           LeaveRequest[]
  reviewedLeaves          LeaveRequest[]          @relation("ReviewedLeaves")
  workSchedules           WorkSchedule[]
  attendance              Attendance[]
  infractions             Infraction[]            @relation("InfractionUsers")
  createdInfractions      Infraction[]            @relation("InfractionCreators")
  acknowledgedInfractions Infraction[]            @relation("InfractionAckUsers")
  managedBrands           Brand[]                 @relation("BrandManagers")
  brandManagerHistory     BrandManagerHistory[]   @relation("BrandManagerHistoryPerformedBy")
  managedBrandsHistory    BrandManagerHistory[]   @relation("BrandManagerHistoryUsers")
  performedStatusHistory  EmployeeStatusHistory[] @relation("EmployeeStatusHistoryPerformedBy")

  // Archive Audit Relations
  archivedLeaveTypes       LeaveType[]                @relation("LeaveTypeArchivedBy")
  archivedInfractionTypes  InfractionType[]           @relation("InfractionTypeArchivedBy")
  archivedInfractionOffenses InfractionOffense[]      @relation("InfractionOffenseArchivedBy")
  archivedFeatures         Feature[]                  @relation("FeatureArchivedBy")
  archivedNavTemplates     FeatureNavigationTemplate[] @relation("NavTemplateArchivedBy")
  archivedRoleNavigations  RoleNavigation[]            @relation("RoleNavigationArchivedBy")

  @@index([companyId], map: "users_company_id_fkey")
  @@map("users")
}

model EmployeeProfile {
  id                       String                  @id @default(uuid())
  userId                   String                  @unique @map("user_id")
  firstName                String                  @map("first_name") @db.VarChar(100)
  lastName                 String                  @map("last_name") @db.VarChar(100)
  middleName               String?                 @map("middle_name") @db.VarChar(100)
  dateOfBirth              DateTime?               @map("date_of_birth")
  contactNumber            String?                 @map("contact_number") @db.VarChar(20)
  personalEmail            String?                 @map("personal_email") @db.VarChar(255)
  address                  String?                 @db.Text
  hireDate                 DateTime?               @map("hire_date")
  emergencyContactName     String?                 @map("emergency_contact_name") @db.VarChar(200)
  emergencyContactNumber   String?                 @map("emergency_contact_number") @db.VarChar(50)
  emergencyContactRelation String?                 @map("emergency_contact_relation") @db.VarChar(100)
  createdAt                DateTime                @default(now()) @map("created_at")
  updatedAt                DateTime                @updatedAt @map("updated_at")
  departmentId             String?                 @map("department_id")
  positionId               String?                 @map("position_id")
  statusId                 String                  @default("1") @map("status_id")
  roleId                   String                  @default("3") @map("role_id")
  department               Department?             @relation(fields: [departmentId], references: [id])
  position                 Position?               @relation(fields: [positionId], references: [id])
  status                   EmployeeStatusModel     @relation(fields: [statusId], references: [id])
  role                     Role                    @relation(fields: [roleId], references: [id])
  user                     User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  statusHistory            EmployeeStatusHistory[]

  @@index([departmentId], map: "employee_profiles_department_id_fkey")
  @@index([positionId], map: "employee_profiles_position_id_fkey")
  @@index([statusId], map: "employee_profiles_status_id_fkey")
  @@index([roleId], map: "employee_profiles_role_id_fkey")
  @@map("employee_profiles")
}

model EmployeeStatusHistory {
  id              String              @id @default(uuid())
  userId          String              @map("user_id")
  employeeProfile EmployeeProfile     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  statusId        String              @map("status_id")
  status          EmployeeStatusModel @relation(fields: [statusId], references: [id])
  effectiveDate   DateTime            @default(now()) @map("effective_date")
  reason          String?             @db.Text
  notes           String?             @db.Text
  performedBy     String              @map("performed_by")
  performedByUser User                @relation("EmployeeStatusHistoryPerformedBy", fields: [performedBy], references: [id])
  createdAt       DateTime            @default(now()) @map("created_at")
  ipAddress       String?             @map("ip_address") @db.VarChar(45)
  userAgent       String?             @map("user_agent") @db.Text

  @@index([userId], map: "employee_status_history_user_id_fkey")
  @@index([statusId], map: "employee_status_history_status_id_fkey")
  @@index([performedBy], map: "employee_status_history_performed_by_fkey")
  @@index([effectiveDate], map: "employee_status_history_effective_date_idx")
  @@map("employee_status_history")
}

model Brand {
  id             String                @id @default(uuid())
  companyId      String                @default("1") @map("company_id")
  name           String                @unique @db.VarChar(100)
  description    String?               @db.Text
  logo           String?               @db.VarChar(500)
  website        String?               @db.VarChar(255)
  status         BrandStatus           @default(active)
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  createdBy      String                @map("created_by")
  managerId      String?               @map("manager_id")
  company        Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  manager        User?                 @relation("BrandManagers", fields: [managerId], references: [id])
  industryId     String?               @map("industry_id")
  industry       Industry?             @relation(fields: [industryId], references: [id])
  teams          Team[]
  managerHistory BrandManagerHistory[]

  @@index([industryId], map: "brands_industry_id_fkey")
  @@index([managerId], map: "brands_manager_id_fkey")
  @@index([companyId], map: "brands_company_id_fkey")
  @@map("brands")
}

enum BrandManagerAction {
  ASSIGNED
  REMOVED
}

model BrandManagerHistory {
  id                String             @id @default(uuid())
  brandId           String
  brand             Brand              @relation(fields: [brandId], references: [id])
  userId            String?            @map("user_id")
  user              User?              @relation("BrandManagerHistoryUsers", fields: [userId], references: [id])
  action            BrandManagerAction
  performedBy       String             @map("performed_by")
  performedByUser   User               @relation("BrandManagerHistoryPerformedBy", fields: [performedBy], references: [id])
  timestamp         DateTime           @default(now())
  previousManagerId String?            @map("previous_manager_id")
  reason            String?            @db.Text
  ipAddress         String?            @map("ip_address") @db.VarChar(45)
  userAgent         String?            @map("user_agent") @db.Text

  @@index([brandId], map: "brand_manager_history_brand_id_fkey")
  @@index([userId], map: "brand_manager_history_user_id_fkey")
  @@index([performedBy], map: "brand_manager_history_performed_by_fkey")
  @@index([timestamp], map: "brand_manager_history_timestamp_fkey")
  @@map("brand_manager_history")
}

model Team {
  id          String        @id @default(uuid())
  companyId   String        @default("1") @map("company_id")
  name        String        @unique @db.VarChar(100)
  description String?       @db.Text
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  brandId     String        @map("brand_id")
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  history     TeamHistory[]
  members     TeamMember[]
  brand       Brand         @relation(fields: [brandId], references: [id])

  @@index([brandId], map: "teams_brand_id_fkey")
  @@index([companyId], map: "teams_company_id_fkey")
  @@map("teams")
}

model TeamMember {
  id       String           @id @default(uuid())
  teamId   String           @map("team_id")
  userId   String           @map("user_id")
  isLeader Boolean          @default(false) @map("is_leader")
  status   TeamMemberStatus @default(active)
  joinedAt DateTime         @default(now()) @map("joined_at")
  leftAt   DateTime?        @map("left_at")
  history  TeamHistory[]
  team     Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([teamId], map: "team_members_team_id_fkey")
  @@index([userId], map: "team_members_user_id_fkey")
  @@map("team_members")
}

model TeamHistory {
  id           String            @id @default(uuid())
  teamId       String            @map("team_id")
  teamMemberId String?           @map("team_member_id")
  action       TeamHistoryAction
  performedBy  String            @map("performed_by")
  reason       String?           @db.Text
  metadata     Json?
  createdAt    DateTime          @default(now()) @map("created_at")
  team         Team              @relation(fields: [teamId], references: [id])
  teamMember   TeamMember?       @relation(fields: [teamMemberId], references: [id])

  @@index([teamId], map: "team_history_team_id_fkey")
  @@index([teamMemberId], map: "team_history_team_member_id_fkey")
  @@map("team_history")
}

enum BrandStatus {
  active
  inactive
  archived
}

enum TeamMemberStatus {
  active
  inactive
}

enum TeamHistoryAction {
  joined
  left
  promoted
  demoted
  removed
  created
  updated
}

model CalendarEvent {
  id          String   @id @default(uuid())
  companyId   String   @default("1") @map("company_id")
  title       String   @db.VarChar(200)
  description String?  @db.Text
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  color       String   @default("blue") @db.VarChar(20)
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [createdBy], references: [id])
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([startDate], map: "calendar_events_start_date_idx")
  @@index([createdBy], map: "calendar_events_created_by_idx")
  @@map("calendar_events")
}

model LeaveType {
  id               String         @id @default(uuid())
  companyId        String         @default("1") @map("company_id")
  name             String         @db.VarChar(50)
  description      String?        @db.Text
  defaultDaysLimit Int?           @map("default_days_limit")
  color            String         @default("purple") @db.VarChar(20)
  archivedAt       DateTime?      @map("archived_at")
  archivedBy       String?        @map("archived_by")
  createdAt        DateTime       @default(now()) @map("created_at")
  leaveRequests    LeaveRequest[]
  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  archivedByUser   User?          @relation("LeaveTypeArchivedBy", fields: [archivedBy], references: [id])

  @@unique([companyId, name])
  @@index([companyId])
  @@index([archivedBy])
  @@map("leave_types")
}

model LeaveStatus {
  id            String         @id @default(uuid())
  companyId     String         @default("1") @map("company_id")
  name          String         @db.VarChar(50)
  description   String?        @db.Text
  color         String         @default("gray") @db.VarChar(20)
  isFinal       Boolean        @default(false) @map("is_final")
  createdAt     DateTime       @default(now()) @map("created_at")
  leaveRequests LeaveRequest[]
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@map("leave_statuses")
}

model LeaveCredit {
  id         String       @id @default(uuid())
  userId     String       @map("user_id")
  earnedDate DateTime     @map("earned_date")
  usedDate   DateTime?    @map("used_date")
  createdAt  DateTime     @default(now()) @map("created_at")
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveUsage LeaveUsage[]

  @@index([userId], map: "leave_credits_user_id_idx")
  @@index([earnedDate], map: "leave_credits_earned_date_idx")
  @@map("leave_credits")
}

model LeaveRequest {
  id            String    @id @default(uuid())
  companyId     String    @default("1") @map("company_id")
  userId        String    @map("user_id")
  leaveTypeId   String    @map("leave_type_id")
  statusId      String    @default("1") @map("status_id")
  startDate     DateTime  @map("start_date")
  endDate       DateTime  @map("end_date")
  reason        String?   @db.Text
  isPaid        Boolean   @default(true) @map("is_paid")
  reviewedBy    String?   @map("reviewed_by")
  reviewedAt    DateTime? @map("reviewed_at")
  reviewComment String?   @map("review_comment") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user       User         @relation(fields: [userId], references: [id])
  leaveType  LeaveType    @relation(fields: [leaveTypeId], references: [id])
  status     LeaveStatus  @relation(fields: [statusId], references: [id])
  reviewer   User?        @relation("ReviewedLeaves", fields: [reviewedBy], references: [id])
  company    Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leaveUsage LeaveUsage[]

  @@index([companyId])
  @@index([userId], map: "leave_requests_user_id_idx")
  @@index([statusId], map: "leave_requests_status_id_idx")
  @@index([leaveTypeId], map: "leave_requests_leave_type_id_idx")
  @@index([startDate], map: "leave_requests_start_date_idx")
  @@map("leave_requests")
}

model LeaveUsage {
  id             String   @id @default(uuid())
  leaveRequestId String   @map("leave_request_id")
  leaveCreditId  String   @map("leave_credit_id")
  createdAt      DateTime @default(now()) @map("created_at")

  leaveRequest LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  leaveCredit  LeaveCredit  @relation(fields: [leaveCreditId], references: [id], onDelete: Cascade)

  @@unique([leaveRequestId, leaveCreditId])
  @@index([leaveRequestId], map: "leave_usage_leave_request_id_idx")
  @@index([leaveCreditId], map: "leave_usage_leave_credit_id_idx")
  @@map("leave_usage")
}

model WorkSchedule {
  id            String       @id @default(uuid())
  userId        String       @map("user_id")
  companyId     String       @default("1") @map("company_id")
  dayOfWeek     Int          @map("day_of_week") // 0=Sunday, 1=Monday, ..., 6=Saturday
  startTime     String       @map("start_time") // Format: "HH:MM" (24-hour)
  endTime       String       @map("end_time") // Format: "HH:MM" (24-hour)
  breakMinutes  Int          @default(60) @map("break_minutes")
  effectiveFrom DateTime     @map("effective_from")
  effectiveTo   DateTime?    @map("effective_to") // NULL = indefinitely
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  company       Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  attendance    Attendance[]

  @@index([companyId])
  @@index([userId], map: "work_schedules_user_id_idx")
  @@index([dayOfWeek], map: "work_schedules_day_of_week_idx")
  @@map("work_schedules")
}

model Attendance {
  id                  String           @id @default(uuid())
  userId              String           @map("user_id")
  scheduleId          String?          @map("schedule_id")
  date                DateTime         @db.Date
  clockIn             DateTime?        @map("clock_in")
  clockOut            DateTime?        @map("clock_out")
  status              AttendanceStatus @default(present)
  lateMinutes         Int              @default(0) @map("late_minutes")
  undertimeMinutes    Int              @default(0) @map("undertime_minutes")
  earlyClockOutReason String?          @map("early_clock_out_reason") @db.Text
  notes               String?          @db.Text
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  user                User             @relation(fields: [userId], references: [id])
  schedule            WorkSchedule?    @relation(fields: [scheduleId], references: [id])

  @@unique([userId, date])
  @@index([userId], map: "attendance_user_id_idx")
  @@index([date], map: "attendance_date_idx")
  @@index([status], map: "attendance_status_idx")
  @@map("attendance")
}

enum FeatureKind {
  page
  api
  action
}

enum ScopeLevel {
  self
  team
  department
  brand
  company
}

enum EffectType {
  allow
  deny
}

enum AttendanceStatus {
  present
  absent
  late
  undertime
  on_leave
  holiday
}

model InfractionType {
  id          String              @id @default(uuid())
  companyId   String              @default("1") @map("company_id")
  name        String              @db.VarChar(100)
  description String?             @db.Text
  color       String              @default("red") @db.VarChar(20)
  archivedAt  DateTime?           @map("archived_at")
  archivedBy  String?             @map("archived_by")
  createdAt   DateTime            @default(now()) @map("created_at")
  offenses    InfractionOffense[]
  infractions Infraction[]
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  archivedByUser User?           @relation("InfractionTypeArchivedBy", fields: [archivedBy], references: [id])

  @@unique([companyId, name])
  @@index([companyId])
  @@index([archivedBy])
  @@map("infraction_types")
}

model InfractionOffense {
  id            String         @id @default(uuid())
  companyId     String         @default("1") @map("company_id")
  name          String         @db.VarChar(100)
  description   String?        @db.Text
  severityLevel Int            @map("severity_level") // 1=Minor, 2=Major, 3=Severe
  typeId        String         @map("type_id")
  type          InfractionType @relation(fields: [typeId], references: [id])
  archivedAt    DateTime?      @map("archived_at")
  archivedBy    String?        @map("archived_by")
  createdAt     DateTime       @default(now()) @map("created_at")
  infractions   Infraction[]
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  archivedByUser User?        @relation("InfractionOffenseArchivedBy", fields: [archivedBy], references: [id])

  @@unique([companyId, name])
  @@index([companyId])
  @@index([typeId], map: "infraction_offenses_type_id_fkey")
  @@index([archivedBy])
  @@map("infraction_offenses")
}

model Infraction {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  companyId      String    @default("1") @map("company_id")
  offenseId      String    @map("offense_id")
  typeId         String    @map("type_id")
  date           DateTime  @db.Date
  details        String?   @db.Text
  comment        String?   @db.Text
  acknowledgedBy String?   @map("acknowledged_by")
  acknowledgedAt DateTime? @map("acknowledged_at")
  createdBy      String    @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user    User              @relation("InfractionUsers", fields: [userId], references: [id])
  company Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  offense InfractionOffense @relation(fields: [offenseId], references: [id])
  type    InfractionType    @relation(fields: [typeId], references: [id])
  creator User              @relation("InfractionCreators", fields: [createdBy], references: [id])
  ackUser User?             @relation("InfractionAckUsers", fields: [acknowledgedBy], references: [id])

  @@index([companyId])
  @@index([userId], map: "infractions_user_id_idx")
  @@index([typeId], map: "infractions_type_id_idx")
  @@index([offenseId], map: "infractions_offense_id_idx")
  @@index([date], map: "infractions_date_idx")
  @@map("infractions")
}

model Feature {
  id          String      @id @default(uuid())
  code        String      @db.VarChar(150)
  kind        FeatureKind
  httpMethod  String?     @map("http_method") @db.VarChar(10)
  path        String      @db.VarChar(255)
  name        String      @db.VarChar(120)
  description String?     @db.Text
  domain      String      @db.VarChar(50)
  archivedAt  DateTime?   @map("archived_at")
  archivedBy  String?     @map("archived_by")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  FeatureNavigationItem FeatureNavigationItem[]
  archivedByUser        User? @relation("FeatureArchivedBy", fields: [archivedBy], references: [id])

  @@unique([code], map: "uq_feature_code")
  @@unique([path, httpMethod], map: "uq_feature_path_method")
  @@index([archivedBy])
  @@map("features")
}

model FeatureNavigationTemplate {
  id          String   @id @default(uuid())
  code        String   @db.VarChar(100)
  name        String   @db.VarChar(120)
  description String?  @db.Text
  companyId   String?  @map("company_id")
  isSystem    Boolean  @default(false) @map("is_system")
  archivedAt  DateTime? @map("archived_at")
  archivedBy  String?  @map("archived_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  items    FeatureNavigationItem[]
  roleNavs RoleNavigation[]
  company  Company?                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  archivedByUser User? @relation("NavTemplateArchivedBy", fields: [archivedBy], references: [id])

  @@unique([code], map: "uq_nav_template_code")
  @@index([companyId])
  @@index([archivedBy])
  @@map("feature_navigation_templates")
}

model FeatureNavigationItem {
  id          String   @id @default(uuid())
  templateId  String   @map("template_id")
  parentId    String?  @map("parent_id")
  code        String   @db.VarChar(100)
  name        String   @db.VarChar(120)
  alias       String?  @db.VarChar(120)
  icon        String?  @db.VarChar(50)
  type        String   @db.VarChar(20)
  sortOrder   Int      @default(0) @map("sort_order")
  featureCode String?  @map("feature_code") @db.VarChar(150)
  url         String?  @db.VarChar(255)
  permissions Json?    @default("{\"view\": true, \"create\": false, \"edit\": false, \"delete\": false, \"approve\": false}")
  createdAt   DateTime @default(now()) @map("created_at")

  template FeatureNavigationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  parent   FeatureNavigationItem?    @relation("ItemHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children FeatureNavigationItem[]   @relation("ItemHierarchy")
  feature  Feature?                  @relation(fields: [featureCode], references: [code])

  @@unique([templateId, code], map: "uq_nav_item_template_code")
  @@index([templateId])
  @@index([parentId])
  @@index([featureCode])
  @@map("feature_navigation_items")
}

model RoleNavigation {
  id                   String   @id @default(uuid())
  companyId            String   @map("company_id")
  roleId               String   @map("role_id")
  navigationTemplateId String   @map("navigation_template_id")
  archivedAt           DateTime? @map("archived_at")
  archivedBy           String?   @map("archived_by")
  createdAt            DateTime @default(now()) @map("created_at")

  template FeatureNavigationTemplate @relation(fields: [navigationTemplateId], references: [id], onDelete: Cascade)
  role     Role                      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  company  Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  archivedByUser User? @relation("RoleNavigationArchivedBy", fields: [archivedBy], references: [id])

  @@unique([companyId, roleId], map: "uq_role_navigation")
  @@index([companyId])
  @@index([roleId])
  @@index([navigationTemplateId])
  @@index([archivedBy])
  @@map("role_navigations")
}